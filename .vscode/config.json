{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.classAttributes": ["class", "ui"],
  "tailwindCSS.experimental.classRegex": [["['\"`]([^'\"`]*)['\"`]"]],
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 240,
  "editor.wrappingIndent": "indent"
}
